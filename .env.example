# =============================================================================
# 火种系统 (FireSeed) 环境变量配置模板
# =============================================================================
# 使用方法：
#   cp .env.example .env
#   然后编辑 .env 文件，将所有占位符替换为实际值（生产环境必须替换）。
#   .env 文件包含敏感信息，请勿提交到版本控制系统（已在 .gitignore 中忽略）。
# =============================================================================

# ----- 币安主交易所 API -----
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ----- 备用交易所 API (可选) -----
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here

# ----- 冷数据云存储 -----
# 阿里云 OSS
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
# 腾讯云 COS
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
# AWS S3 (可选，也可使用 IAM 角色)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# MinIO 私有部署
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# 冷数据归档加密密钥（32字节，可使用 openssl rand -hex 16 生成）
COLD_STORAGE_ENCRYPTION_KEY=your_32_byte_hex_key_here

# ----- JWT 令牌与认证 -----
# JWT 签名密钥（推荐使用 openssl rand -hex 32 生成）
JWT_SECRET=your_jwt_secret_here

# 主控密码的 bcrypt 哈希（cost=12）
# 生成方式：python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt(12)).decode())"
AUTH_PASSWORD_HASH=your_bcrypt_hash_here

# TOTP 密钥（经过系统主密钥加密后的 Base64 编码）
# 初次部署时可由火种助手生成，或使用 Python 脚本预生成
TOTP_ENCRYPTED_KEY=your_encrypted_totp_key_here

# 主加密密钥（用于加密 TOTP 密钥等敏感数据，32字节，推荐 openssl rand -hex 16）
MASTER_ENCRYPTION_KEY=your_master_encryption_key_here

# ----- 消息推送渠道 -----
# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 钉钉机器人 Webhook URL
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_SECRET=your_dingtalk_sign_secret_here
# 企业微信
WECOM_CORP_ID=your_wecom_corp_id
WECOM_AGENT_ID=your_wecom_agent_id
WECOM_SECRET=your_wecom_secret_here
# 微信公众号（模板消息）
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_TEMPLATE_ID=your_template_message_id

# ----- 多账户跟单 -----
# 子账户 API 密钥（最多 6 个，按需配置）
SUB1_API_KEY=your_sub1_api_key
SUB1_API_SECRET=your_sub1_api_secret
SUB2_API_KEY=your_sub2_api_key
SUB2_API_SECRET=your_sub2_api_secret
SUB3_API_KEY=your_sub3_api_key
SUB3_API_SECRET=your_sub3_api_secret
SUB4_API_KEY=your_sub4_api_key
SUB4_API_SECRET=your_sub4_api_secret
SUB5_API_KEY=your_sub5_api_key
SUB5_API_SECRET=your_sub5_api_secret
SUB6_API_KEY=your_sub6_api_key
SUB6_API_SECRET=your_sub6_api_secret

# ----- 大语言模型 API（可选，用于火种助手与进化工厂）-----
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ----- 网络与部署 -----
API_HOST=0.0.0.0
API_PORT=8000
# 若启用 HTTPS，请设置以下两个变量（Let's Encrypt 证书路径）
SSL_CERT=/etc/letsencrypt/live/your_domain/fullchain.pem
SSL_KEY=/etc/letsencrypt/live/your_domain/privkey.pem

# ----- 环境标识（development / production）-----
ENV=production
